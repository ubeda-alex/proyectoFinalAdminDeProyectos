generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("CLIENT") // "CLIENT" or "ARTIST"
  createdAt    DateTime @default(now())

  artistProfile Artist?
  clientProfile Client?
}

model Artist {
  id          String    @id @default(uuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  portfolio   String?
  category    String
  status      String    @default("pending")
  description String?
  basePrice   Float?
  location    String?
  services    Service[]
  bookings    Booking[]
}

model Service {
  id           String    @id @default(uuid())
  artistId     String
  artist       Artist    @relation(fields: [artistId], references: [id], onDelete: Cascade)
  name         String
  description  String
  duration     String?
  requirements String?
  createdAt    DateTime  @default(now())
  bookings     Booking[]
}

model Client {
  id       String    @id @default(uuid())
  userId   String    @unique
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings Booking[]
}

model Booking {
  id              String    @id @default(uuid())
  clientId        String
  client          Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  artistId        String
  artist          Artist    @relation(fields: [artistId], references: [id], onDelete: Cascade)
  serviceId       String?
  service         Service?  @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  status          String    @default("REQUESTED") // REQUESTED | ACCEPTED | COMPLETED | REJECTED
  eventDate       DateTime?
  message         String?
  responseMessage String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}
