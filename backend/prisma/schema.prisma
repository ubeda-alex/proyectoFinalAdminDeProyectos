generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("CLIENT") // "CLIENT" or "ARTIST"
  createdAt    DateTime @default(now())

  artistProfile Artist?
  clientProfile Client?
}

model Artist {
  id          String    @id @default(uuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  portfolio   String?
  category    String
  status      String    @default("pending")
  description String?
  basePrice   Float?
  location    String?
  services    Service[]
}

model Service {
  id           String   @id @default(uuid())
  artistId     String
  artist       Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)
  name         String
  description  String
  duration     String?
  requirements String?
  createdAt    DateTime @default(now())
}

model Client {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}
